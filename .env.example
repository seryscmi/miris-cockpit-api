# M.IRIS Cockpit Admin-Dienst — Beispiel-Konfiguration.
# NICHT committen. Auf Render/Fly als Environment-Variablen eintragen.

# Bearer-Token, mit dem sich das Cockpit authentifiziert (langes Zufallsgeheimnis).
# Erzeuge z.B. mit:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=

# Nur diese Origin darf zugreifen (deine GitHub-Pages-URL).
ALLOWED_ORIGIN=https://seryscmi.github.io

# Shopify Admin API
SHOPIFY_SHOP=9zjzs5-ri.myshopify.com
SHOPIFY_STORE_HANDLE=9zjzs5-ri
SHOPIFY_API_VERSION=2024-10
# Neuer Standard (Dev Dashboard): Client ID + Client Secret der App.
# Das Backend holt daraus automatisch einen 24h-Token (client_credentials) und erneuert ihn.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# Optional/alt: statischer Admin-Token (nur falls verfügbar; sonst leer lassen)
SHOPIFY_ADMIN_TOKEN=

# Cloudinary (Augenbilder löschen)
CLOUDINARY_CLOUD_NAME=dg3k6nvwj
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Klaviyo (Phase 3): Kundenanliegen live aus der Chat-Eskalations-Metrik lesen.
# Derselbe private API-Key, den das Mary-Backend nutzt (KLAVIYO_PRIVATE_API_KEY).
KLAVIYO_PRIVATE_API_KEY=
KLAVIYO_ESCALATION_METRIC=MIRIS_CHAT_ESCALATION
KLAVIYO_REVISION=2026-04-15

PORT=8080
